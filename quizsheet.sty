\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{quizsheet}[2026/03/29 Quiz sheet table style]

\RequirePackage{array}
\RequirePackage{amsmath}
\RequirePackage{longtable}
\RequirePackage{etoolbox}
\RequirePackage{makecell}
\RequirePackage{booktabs}
\RequirePackage[table]{xcolor}

\RequirePackage{url}                %URL
\RequirePackage[version=3]{mhchem}  %化学式

% longtable spacing
\setlength{\LTpre}{\medskipamount}
\setlength{\LTpost}{0pt}

% ====================
% Settings
% ====================
% 表の幅の設定
\newlength{\QuizQuestionW}
\newlength{\QuizAnswerW}
\newlength{\QuizCommentW}
\newlength{\QuizNoW}
\newlength{\QuizInnerQuestionW}
\newlength{\QuizInnerAnswerW}
\newlength{\QuizInnerShift}
\newlength{\QuizInnerPad}
\newlength{\QuizCellVMargin}
\newlength{\QuizAnswerShift}
\newlength{\QuizBaseTabColSep}
\newlength{\QuizBaseArrayRuleW}
\newlength{\quiz@savedtabcolsep}
\newlength{\quiz@savedarrayrulewidth}
\setlength{\QuizQuestionW}{13cm}
\setlength{\QuizAnswerW}{3cm}
\setlength{\QuizCommentW}{0pt}
\setlength{\QuizNoW}{6mm}
\setlength{\QuizInnerShift}{6pt}
\setlength{\QuizInnerPad}{4pt}
\setlength{\QuizCellVMargin}{1pt}
\setlength{\QuizBaseTabColSep}{6pt}
\setlength{\QuizBaseArrayRuleW}{0.4pt}

% Keep cell contents tight against the rule lines.
\newcommand{\quiz@cellwithvspace}[1]{%
  \vspace*{\dimexpr\QuizCellVMargin-\f@size pt\relax}
  #1%
  \vspace*{\QuizCellVMargin}
}

%% 日本語イタリック風表示のフォント分岐。
\newif\ifquiz@jpitalicfontavailable
\quiz@jpitalicfontavailablefalse
\newcommand{\quiz@jpitalicbasefont}{}
\IfFontExistsTF{HaranoAjiMincho-Medium}{%
  \renewcommand{\quiz@jpitalicbasefont}{HaranoAjiMincho-Medium}%
  \quiz@jpitalicfontavailabletrue
}{%
  \IfFontExistsTF{IPAexMincho}{%
    \renewcommand{\quiz@jpitalicbasefont}{IPAexMincho}%
    \quiz@jpitalicfontavailabletrue
  }{%
    \IfFontExistsTF{HaranoAjiMincho-Regular}{%
      \renewcommand{\quiz@jpitalicbasefont}{HaranoAjiMincho-Regular}%
      \quiz@jpitalicfontavailabletrue
    }{}
  }%
}
\ifquiz@jpitalicfontavailable
  \newjfontfamily\quiz@jpitalicfont[
    FakeSlant=0.25
  ]{\quiz@jpitalicbasefont}
  \newcommand{\quizitalic}[1]{{\quiz@jpitalicfont #1}}
\else
  \newcommand{\quizitalic}[1]{\textsl{#1}}
\fi
\renewcommand{\textit}[1]{\quizitalic{#1}}

% Counter
\newcounter{question}
\renewcommand{\thequestion}{\arabic{question}}

% State
\newif\ifquiz@open
\quiz@openfalse
\newif\ifquiz@tablemetricsapplied
\quiz@tablemetricsappliedfalse
\newif\ifquiz@pageheaderused
\quiz@pageheaderusedfalse
\newcount\quiz@lastheaderpage
\quiz@lastheaderpage=-1
\newif\ifquiz@nearpagetop
\newcount\quiz@tablestartpage
\quiz@tablestartpage=-1
\newcount\quiz@lasttableclosepage
\quiz@lasttableclosepage=-1
\newcommand{\quiz@subtitle}{}

\newcommand{\quiz@detectnearpagetop}{%
  \ifdim\dimexpr\pagegoal-\pagetotal\relax>0.65\textheight
    \quiz@nearpagetoptrue
  \else
    \quiz@nearpagetopfalse
  \fi
}

\newcommand{\quiz@lastquestion}{0}
\let\quiz@originallabel\label
\newcommand{\quiz@questionlabel}[1]{%
  \begingroup
    \protected@edef\@currentlabel{\quiz@lastquestion}%
    \quiz@originallabel{#1}%
  \endgroup
}

\newcommand{\QuestionLabel}[1]{%
  \quiz@questionlabel{#1}%
}

\newcommand{\quiz@applytablemetrics}{%
  \ifquiz@tablemetricsapplied\else
    \setlength{\quiz@savedtabcolsep}{\tabcolsep}%
    \setlength{\quiz@savedarrayrulewidth}{\arrayrulewidth}%
    \setlength{\tabcolsep}{\QuizBaseTabColSep}%
    \setlength{\arrayrulewidth}{\QuizBaseArrayRuleW}%
    \quiz@tablemetricsappliedtrue
  \fi
}

\newcommand{\quiz@restoretablemetrics}{%
  \ifquiz@tablemetricsapplied
    \setlength{\tabcolsep}{\quiz@savedtabcolsep}%
    \setlength{\arrayrulewidth}{\quiz@savedarrayrulewidth}%
    \quiz@tablemetricsappliedfalse
  \fi
}

\AddToHook{shipout/after}{%
  \global\quiz@pageheaderusedfalse
}

% Title helpers
\newcommand{\@subtitle}{}
\newcommand{\subtitle}[1]{\gdef\@subtitle{#1}}
\newcommand{\@license}{}
\newcommand{\license}[1]{\gdef\@license{#1}}
\let\quiz@orig@maketitle\maketitle
\newcommand{\quiz@savedtitle}{}
\newcommand{\quiz@saveddate}{}
\renewcommand{\maketitle}{%
  \let\quiz@savedtitle\@title
  \let\quiz@saveddate\@date
  \ifstrempty{\@subtitle}{}{%
    \gdef\@title{\quiz@savedtitle\\\large \@subtitle}%
  }%
  \ifstrempty{\@license}{}{%
    \ifstrempty{\quiz@saveddate}{%
      \gdef\@date{\vfill {\small \@license}}%
    }{%
      \gdef\@date{\quiz@saveddate\vfill {\small \@license}}%
    }%
  }%
  \quiz@orig@maketitle
  \global\let\@title\quiz@savedtitle
  \global\let\@date\quiz@saveddate
}

\newcommand{\quiz@recalcwidths}{%
  \setlength{\QuizCommentW}{\dimexpr\QuizQuestionW+\QuizAnswerW+2\QuizBaseTabColSep+\QuizBaseArrayRuleW\relax}%
  \setlength{\QuizInnerAnswerW}{\dimexpr(\QuizCommentW-\QuizBaseArrayRuleW-2\QuizInnerPad)*2/10\relax}%
  \setlength{\QuizInnerQuestionW}{\dimexpr\QuizCommentW-\QuizBaseArrayRuleW-2\QuizInnerPad-\QuizInnerAnswerW\relax}%
}
\quiz@recalcwidths

\newcommand{\quizsetwidths}[3]{%
  \setlength{\QuizQuestionW}{#1}%
  \setlength{\QuizAnswerW}{#2}%
  \quiz@recalcwidths%
}

\newcommand{\quizsetinnerwidths}[2]{%
  \setlength{\QuizInnerQuestionW}{#1}%
  \setlength{\QuizInnerAnswerW}{#2}%
  \setlength{\QuizQuestionW}{\dimexpr\QuizInnerQuestionW+\QuizInnerPad-\QuizBaseTabColSep\relax}%
  \setlength{\QuizAnswerW}{\dimexpr\QuizInnerAnswerW+\QuizInnerPad-\QuizBaseTabColSep\relax}%
  \setlength{\QuizCommentW}{\dimexpr\QuizQuestionW+\QuizAnswerW+2\QuizBaseTabColSep+\QuizBaseArrayRuleW\relax}%
}

% \newcommand{\quizsetanswershift}[1]{%
%   \setlength{\QuizAnswerShift}{#1}%
% }

% ====================
% Layout
% ====================
\newcolumntype{N}{>{\raggedleft\arraybackslash}p{\QuizNoW}}
\newcolumntype{B}{>{\raggedright\arraybackslash}p{\QuizQuestionW}}
\newcolumntype{C}{>{\raggedright\arraybackslash}p{\QuizAnswerW}}

\newcommand{\quiz@headerrow}{%
  \rowcolor{black}
  \multicolumn{1}{|c}{\cellcolor{black}{\color{white} \textbf{No.}}}
    & \multicolumn{2}{c|}{\cellcolor{black}{\color{white}%
        \makebox[\dimexpr\QuizInnerQuestionW+2\QuizInnerPad-2\tabcolsep\relax][c]{\textbf{問題}}%
        \makebox[\dimexpr\QuizInnerAnswerW+2\QuizInnerPad-2\tabcolsep\relax][c]{\hspace*{1em}\textbf{正解}}%
      }} \\ \hline
}

\newcommand{\quiz@showheaderonceperpage}{%
  \ifquiz@pageheaderused
    \hline
  \else
    \quiz@headerrow
    \noalign{\global\quiz@pageheaderusedtrue}
  \fi
}

\newcommand{\quiz@starttable}[1]{%
  \def\quiz@subtitle{#1}%
  \global\quiz@tablestartpage=\numexpr\value{page}\relax
  \quiz@applytablemetrics
  \quiz@opentrue
  \quiz@starttable@withheader{#1}%
}

\newcommand{\quiz@starttable@withheader}[1]{%
  \begin{longtable}{|N|B|C|}
  % \QuizSection 実行時と実際の表開始ページがずれた場合は、
  % 新ページ先頭としてヘッダー表示を許可する。
  \ifnum\quiz@tablestartpage<\numexpr\value{page}\relax
    \global\quiz@pageheaderusedfalse
  \fi
  \quiz@showheaderonceperpage
  \ifstrempty{#1}{}{%
    \rowcolor[HTML]{CCCCCC}
    \multicolumn{3}{|l|}{\textbf{#1}} \\
    \quiz@thickrule
  }
  \endfirsthead

  %% 改ページ後にもsubsectionの内容を記すか？ オプション。
  % \ifdefempty{\quiz@subtitle}{}{%
  %   \hline
    % \multicolumn{3}{|l|}{続：\quiz@subtitle} \\ \hline
  % }
  \quiz@headerrow
  \noalign{\global\quiz@pageheaderusedtrue}

  \endhead

  \endfoot

  \endlastfoot
}

\newcommand{\quiz@starttable@noheader}[1]{%
  \begin{longtable}{|N|B|C|}
  \hline
  \ifstrempty{#1}{}{%
    \rowcolor[HTML]{CCCCCC}
    \multicolumn{3}{|l|}{\textbf{#1}} \\
    \quiz@thickrule
  }
  \endfirsthead

  \noalign{\global\quiz@pageheaderusedtrue}
  \hline
  \rowcolor{black}
  \multicolumn{1}{|c}{\cellcolor{black}{\color{white} \textbf{No.}}}
    & \multicolumn{2}{c|}{\cellcolor{black}{\color{white}%
        \makebox[\dimexpr\QuizInnerQuestionW+2\QuizInnerPad-2\tabcolsep\relax][c]{\textbf{問題}}%
        \makebox[\dimexpr\QuizInnerAnswerW+2\QuizInnerPad-2\tabcolsep\relax][c]{\hspace*{1em}\textbf{正解}}%
      }} \\ \hline
  \endhead

  \endfoot

  \endlastfoot
}

\newcommand{\quiz@innernoexp}[2]{
  \makebox[\linewidth][l]{%
    \hspace*{-\QuizInnerShift}%
    \begin{tabular*}{\dimexpr\linewidth+\QuizInnerShift\relax}{@{\hspace{\QuizInnerPad}}>{\raggedright\arraybackslash}p{\QuizInnerQuestionW}!{\vrule width \arrayrulewidth}>{\raggedright\arraybackslash}p{\QuizInnerAnswerW}@{\hspace{\QuizInnerPad}}}
      % \cellcolor[HTML]{FFFFFF} %解説枠をより目立たせたい場合は
      \begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#1}\endgroup & \quiz@cellwithvspace{#2} \\
    \end{tabular*}%
  }%
}

\newcommand{\quiz@innerwith}[3]{%
  \makebox[\linewidth][l]{%
    \hspace*{-\QuizInnerShift}%
    \begin{tabular*}{\dimexpr\linewidth+\QuizInnerShift\relax}{@{\hspace{\QuizInnerPad}}>{\raggedright\arraybackslash}p{\QuizInnerQuestionW}!{\vrule width \arrayrulewidth}>{\raggedright\arraybackslash}p{\QuizInnerAnswerW}@{\hspace{\QuizInnerPad}}}
      % \cellcolor[HTML]{FFFFFF} %解説枠をより目立たせたい場合は
      \begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#1}\endgroup & \quiz@cellwithvspace{#2} \\
      \cline{1-2}
      \multicolumn{2}{@{\hspace{\QuizInnerPad}}>{\raggedright\arraybackslash}p{\dimexpr\linewidth-2\QuizInnerPad+2\tabcolsep\relax}@{\hspace{\QuizInnerPad}}}{\begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#3}\endgroup} \\
    \end{tabular*}%
  }%
}

\newcommand{\quiz@thickrule}{%
  \specialrule{1.5pt}{0pt}{0pt}%
}

\newcommand{\quiz@rowrule}{%
  \quiz@thickrule
}

\newcommand{\quiz@innerend}[1]{%
  \makebox[\linewidth][l]{%
    \hspace*{-\QuizInnerShift}%
    \begin{tabular*}{\dimexpr\linewidth+\QuizInnerShift\relax}{@{\hspace{\QuizInnerPad}}>{\raggedright\arraybackslash}p{\QuizInnerQuestionW}>{\raggedleft\arraybackslash}p{\QuizInnerAnswerW}@{\hspace{\QuizInnerPad}}}
      {} & #1 \\
    \end{tabular*}%
  }%
}

\newcommand{\quiz@endmarkerrow}[1]{%
  \multicolumn{1}{>{\raggedleft\arraybackslash}p{\QuizNoW}}{}
    & \multicolumn{2}{>{\raggedright\arraybackslash}p{\QuizCommentW}}{\quiz@innerend{#1}} \\
}

\newcommand{\quiz@numcell}{%
  \refstepcounter{question}%
  \xdef\quiz@lastquestion{\thequestion}%
  \protected@edef\@currentlabel{\quiz@lastquestion}%
  \thequestion
}

\newcommand{\quiz@beforequestion}{%
  \ifhmode
    \unskip\par
  \fi
}

% ====================
% API
% ====================

\newcommand{\quizend}[1]{%
  \ifquiz@open
    \noalign{\vskip0pt}%
    \quiz@endmarkerrow{#1}
    \end{longtable}%
    \quiz@restoretablemetrics
    \quiz@openfalse
    \setlength{\LTpre}{\medskipamount}%
  \fi
}

\newcommand{\quizclose}{%
  \ifquiz@open
    \end{longtable}%
    \global\quiz@lasttableclosepage=\numexpr\value{page}\relax
    \quiz@restoretablemetrics
    \quiz@openfalse
    \setlength{\LTpre}{\medskipamount}%
  \fi
}

%% section/subsectionを跨ぐ際は、問題表を閉じる（以上。は挿入しない）。
\pretocmd{\clearpage}{\quizclose}{}{}
\pretocmd{\section}{\quizclose\setcounter{question}{0}}{}{}
\newcommand{\quiz@onsubsection}{%
  \ifquiz@open
    \quizclose
  \fi
}
% \pretocmd{\subsection}{\quiz@onsubsection}{}{}
% \pretocmd{\subsubsection}{\quiz@onsubsection}{}{}

\newcommand{\QuizSection}[1]{%
  \ifquiz@open
    \quizclose
  \fi
  % 残り領域が極端に少ない場合、実際の表開始は次ページになるため、
  % 次ページ先頭でヘッダーを出せるようフラグを先行リセットする。
  \ifdim\dimexpr\pagegoal-\pagetotal\relax<3\baselineskip
    \global\quiz@pageheaderusedfalse
  \fi
  \quiz@detectnearpagetop
  \ifquiz@nearpagetop
    \global\quiz@pageheaderusedfalse
  \fi
  \setlength{\LTpre}{0pt}%
  \quiz@starttable{#1}%
}

% ====================
% Question Counter Management
% ====================
\newcommand{\renumber}[1][]{%
  \ifstrempty{#1}{%
    % 引数なし：1問目から振り直す
    \setcounter{question}{0}%
  }{%
    % 引数あり：指定番号から振り直す（1以上の整数）
    \ifnum\numexpr#1\relax<1
      \setcounter{question}{0}%
    \else
      \setcounter{question}{\numexpr#1-1\relax}%
    \fi
  }%
}
\newcommand{\question}[3]{%
  \quiz@beforequestion
  \ifquiz@open\else
    \setlength{\LTpre}{\medskipamount}%
    \quiz@starttable{}%
  \fi
  \ifstrempty{#3}{%
    \multicolumn{1}{|>{\raggedleft\arraybackslash}p{\QuizNoW}||}{\quiz@numcell}
      & \multicolumn{2}{>{\raggedright\arraybackslash}p{\QuizCommentW}|}{\quiz@innernoexp{#1}{#2}} \\
    \quiz@rowrule
  }{%
    \multicolumn{1}{|>{\raggedleft\arraybackslash}p{\QuizNoW}||}{\quiz@numcell}
      & \multicolumn{2}{>{\raggedright\arraybackslash}p{\QuizCommentW}|}{\quiz@innerwith{#1}{#2}{#3}} \\
    \quiz@rowrule
  }%
}

\AtEndDocument{\quizend{以上。}}
