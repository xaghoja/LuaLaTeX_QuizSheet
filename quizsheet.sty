\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{quizsheet}[2026/04/20 Quiz sheet table style v3]

\newif\ifquiz@repeatsectiononbreak
\quiz@repeatsectiononbreakfalse
\DeclareOption{repeatsection}{\quiz@repeatsectiononbreaktrue}
\DeclareOption{norepeatsection}{\quiz@repeatsectiononbreakfalse}
\ProcessOptions\relax

\RequirePackage{array}
\RequirePackage{amsmath}
\RequirePackage{longtable}
\RequirePackage{etoolbox}
\RequirePackage{makecell}
\RequirePackage{booktabs}
\RequirePackage[table]{xcolor}
\RequirePackage{multirow}
\RequirePackage{url}
\RequirePackage[version=3]{mhchem}

% Fake slant amount used by \textit for Japanese glyphs.
\newcommand{\QuizItalicFakeSlant}{0.25}

\ifcsname newjfontfamily\endcsname
  \newjfontfamily\quiz@japaneseitalic[
    UprightFont = *,
    ItalicFont = *,
    ItalicFeatures = {FakeSlant=\QuizItalicFakeSlant}
  ]{HaranoAjiMincho-Regular}
\fi

\let\quiz@origtextit\textit
\DeclareRobustCommand{\textit}[1]{%
  \ifcsname quiz@japaneseitalic\endcsname
    {\itshape\quiz@japaneseitalic #1}%
  \else
    \quiz@origtextit{#1}%
  \fi
}

% longtable spacing
\setlength{\LTpre}{\medskipamount}
\setlength{\LTpost}{0pt}

% ====================
% Settings
% ====================

\newlength{\QuizBaseTabColSep}
\newlength{\QuizBaseArrayRuleW}
\newlength{\QuizNoSepRuleW}
\newlength{\QuizOuterVRuleW}
\newlength{\QuizQuestionSepRuleW}
\newlength{\QuizCommentIndent}
\newlength{\QuizCommentRuleShift}
\newlength{\QuizCellVMargin}
\newlength{\QuizCellExtraDepth}
\newlength{\QuizSectionCellVMargin}
\newlength{\QuizSectionCellExtraDepth}
\newlength{\QuizTextBaselineSkip}
\newlength{\QuizRubyGuardRowExtra}
\newlength{\quiz@savedtabcolsep}
\newlength{\quiz@savedarrayrulewidth}
\newlength{\quiz@savedextrarowheight}

\newlength{\QuizBlockW}
\newlength{\QuizInnerW}
\newlength{\QuizNoColW}
\newlength{\QuizQuestionColW}
\newlength{\QuizAnswerColW}
\newlength{\QuizCommentColW}

\setlength{\QuizBaseTabColSep}{6pt}
\setlength{\QuizBaseArrayRuleW}{0.4pt}
\setlength{\QuizNoSepRuleW}{2pt}
\setlength{\QuizOuterVRuleW}{\QuizBaseArrayRuleW}
\setlength{\QuizQuestionSepRuleW}{1.5pt}
\setlength{\QuizCommentIndent}{5pt}
\setlength{\QuizCommentRuleShift}{-7pt}
\setlength{\QuizCellVMargin}{0pt}
\setlength{\QuizCellExtraDepth}{6pt}
\setlength{\QuizSectionCellVMargin}{-1.5pt}
\setlength{\QuizSectionCellExtraDepth}{1pt}
\setlength{\QuizTextBaselineSkip}{\normalbaselineskip}
\setlength{\QuizRubyGuardRowExtra}{3pt}

\newcommand{\quiz@recalcwidths}{%
  \setlength{\QuizBlockW}{\linewidth}%
  \setlength{\QuizInnerW}{\dimexpr\QuizBlockW-6\QuizBaseTabColSep-2\QuizOuterVRuleW-\QuizNoSepRuleW-\QuizBaseArrayRuleW\relax}%
  \setlength{\QuizNoColW}{\dimexpr\QuizInnerW/26\relax}%
  \setlength{\QuizQuestionColW}{\dimexpr\QuizInnerW*20/26\relax}%
  \setlength{\QuizAnswerColW}{\dimexpr\QuizInnerW*5/26\relax}%
  \setlength{\QuizCommentColW}{\dimexpr\QuizQuestionColW+\QuizAnswerColW+2\QuizBaseTabColSep+\QuizBaseArrayRuleW\relax}%
}
\quiz@recalcwidths

\newcommand{\quiz@cellwithvspace}[1]{%
  \noindent\raisebox{-\QuizCellVMargin}{%
    \parbox[t]{\linewidth}{%
      \setlength{\baselineskip}{\QuizTextBaselineSkip}%
      \setlength{\lineskip}{1pt}%
      \setlength{\lineskiplimit}{1pt}%
      \setlength{\parskip}{0pt}%
      \rule{0pt}{\dimexpr\ht\strutbox+\QuizRubyGuardRowExtra\relax}%
      \ignorespaces#1\unskip\ifhmode\strut\fi\vrule width 0pt height 0pt depth \QuizCellExtraDepth
    }%
  }%
}

\newcommand{\quiz@sectioncellwithvspace}[1]{%
  \noindent\raisebox{-\QuizSectionCellVMargin}{\strut\ignorespaces#1\unskip\strut\vrule width 0pt height 0pt depth \QuizSectionCellExtraDepth}%
}

% ====================
% State
% ====================

\newif\ifquiz@open
\quiz@openfalse
\newif\ifquiz@pendingsection
\quiz@pendingsectionfalse
\newif\ifquiz@hasactivesection
\quiz@hasactivesectionfalse
\newif\ifquiz@tablemetricsapplied
\quiz@tablemetricsappliedfalse
\newif\ifquiz@hasquestion
\quiz@hasquestionfalse

\newcommand{\quiz@pendingsectiontitle}{}
\newcommand{\quiz@activesectiontitle}{}
\newcount\quiz@renumberstart
\quiz@renumberstart=1
\newcounter{question}
\renewcommand{\thequestion}{\arabic{question}}
\newcommand{\quiz@lastquestion}{0}

\let\quiz@originallabel\label
\newcommand{\quiz@questionlabel}[1]{%
  \begingroup
    \protected@edef\@currentlabel{\quiz@lastquestion}%
    \quiz@originallabel{#1}%
  \endgroup
}

\newcommand{\quiz@applytablemetrics}{%
  \ifquiz@tablemetricsapplied\else
    \setlength{\quiz@savedtabcolsep}{\tabcolsep}%
    \setlength{\quiz@savedarrayrulewidth}{\arrayrulewidth}%
    \setlength{\quiz@savedextrarowheight}{\extrarowheight}%
    \setlength{\tabcolsep}{\QuizBaseTabColSep}%
    \setlength{\arrayrulewidth}{\QuizBaseArrayRuleW}%
    \setlength{\extrarowheight}{0pt}%
    \quiz@tablemetricsappliedtrue
  \fi
}

\newcommand{\quiz@restoretablemetrics}{%
  \ifquiz@tablemetricsapplied
    \setlength{\tabcolsep}{\quiz@savedtabcolsep}%
    \setlength{\arrayrulewidth}{\quiz@savedarrayrulewidth}%
    \setlength{\extrarowheight}{\quiz@savedextrarowheight}%
    \quiz@tablemetricsappliedfalse
  \fi
}

\newcommand{\quiz@setpendingsection}[1]{%
  \gdef\quiz@pendingsectiontitle{#1}%
  \global\quiz@pendingsectiontrue
}

\newcommand{\quiz@setactivesection}[1]{%
  \gdef\quiz@activesectiontitle{#1}%
  \global\quiz@hasactivesectiontrue
}

\newcommand{\quiz@clearactivesection}{%
  \global\quiz@hasactivesectionfalse
  \gdef\quiz@activesectiontitle{}%
}

\newcommand{\quiz@clearpendingsection}{%
  \global\quiz@pendingsectionfalse
  \gdef\quiz@pendingsectiontitle{}%
}

\newcommand{\quiz@continuedsectionblock}{%
  \ifquiz@repeatsectiononbreak
    \ifquiz@hasactivesection
      \makebox[\QuizBlockW][l]{%
        \begin{tabular*}{\QuizBlockW}{|>{\raggedleft\arraybackslash}p{\QuizNoColW}!{\vrule width \QuizNoSepRuleW}>{\raggedright\arraybackslash}p{\QuizQuestionColW}|>{\raggedright\arraybackslash}p{\QuizAnswerColW}|}
          \multicolumn{3}{|l|}{\cellcolor[HTML]{C0C0C0}\quiz@sectioncellwithvspace{\textbf{\quiz@activesectiontitle}}} \\
          \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
        \end{tabular*}%
      }\\
    \fi
  \fi
}

\ExplSyntaxOn
\cs_new_protected:Npn \quiz_ifblank:nnTF #1#2#3
  {
    \tl_set:Nn \l_tmpa_tl {#1}
    \tl_replace_all:Nnn \l_tmpa_tl { \par } { }
    \tl_if_blank:eTF { \tl_trim_spaces:V \l_tmpa_tl } {#2} {#3}
  }
\newcommand{\quiz@ifblankTF}[3]{\quiz_ifblank:nnTF{#1}{#2}{#3}}
\ExplSyntaxOff

% ====================
% Title helpers
% ====================

\newcommand{\@subtitle}{}
\newcommand{\subtitle}[1]{\gdef\@subtitle{#1}}
\newcommand{\@license}{}
\newcommand{\license}[1]{\gdef\@license{#1}}

\let\quiz@orig@maketitle\maketitle
\newcommand{\quiz@savedtitle}{}
\newcommand{\quiz@saveddate}{}
\renewcommand{\maketitle}{%
  \let\quiz@savedtitle\@title
  \let\quiz@saveddate\@date
  \ifstrempty{\@subtitle}{}{%
    \gdef\@title{\quiz@savedtitle\\\large \@subtitle}%
  }%
  \ifstrempty{\@license}{}{%
    \g@addto@macro\@thanks{\par\vfill\begin{center}\small \@license\end{center}\par}%
  }%
  \quiz@orig@maketitle
  \global\let\@title\quiz@savedtitle
  \global\let\@date\quiz@saveddate
}

% ====================
% Layout blocks
% ====================

\newcommand{\quiz@tenptfont}{\fontsize{10pt}{12pt}\selectfont}
\newcommand{\quiz@headercell}[1]{\quiz@tenptfont\bfseries\rule{0pt}{12pt}#1}

\newcommand{\quiz@headerblock}{%
  \begingroup
    \setlength{\extrarowheight}{0pt}%
    \renewcommand{\arraystretch}{1}%
    \makebox[\QuizBlockW][l]{%
      \begin{tabular*}{\QuizBlockW}{|>{\centering\arraybackslash}m{\QuizNoColW}!{\vrule width \QuizNoSepRuleW}>{\centering\arraybackslash}m{\QuizQuestionColW}|>{\centering\arraybackslash}m{\QuizAnswerColW}|}
        \rowcolor{black}
        \cellcolor{black}{\color{white}\quiz@headercell{No.}}
          & \cellcolor{black}{\color{white}\quiz@headercell{問題}}
          & \cellcolor{black}{\color{white}\quiz@headercell{正解}} \\
        \hline
      \end{tabular*}%
    }%
  \endgroup
}

\newcommand{\quiz@commentcell}[1]{%
  \hspace*{\dimexpr\QuizCommentIndent+\QuizCommentRuleShift\relax}%
  \vrule width \arrayrulewidth
  \hspace*{\QuizCommentIndent}%
  \raisebox{-\QuizCellVMargin}{%
    \parbox[t]{\dimexpr\linewidth-3\QuizCommentIndent-\QuizCommentRuleShift-\arrayrulewidth\relax}{%
      \setlength{\baselineskip}{\QuizTextBaselineSkip}%
      \setlength{\lineskip}{1pt}%
      \setlength{\lineskiplimit}{1pt}%
      \setlength{\parskip}{0pt}%
      \rule{0pt}{\dimexpr\ht\strutbox+\QuizRubyGuardRowExtra\relax}%
      \ignorespaces#1\unskip\ifhmode\strut\fi\vrule width 0pt height 0pt depth \QuizCellExtraDepth
    }%
  }%
}

\newcommand{\quiz@blockrow@noexp}[3]{%
  \makebox[\QuizBlockW][l]{%
    \begin{tabular*}{\QuizBlockW}{|>{\raggedleft\arraybackslash}p{\QuizNoColW}!{\vrule width \QuizNoSepRuleW}>{\raggedright\arraybackslash}p{\QuizQuestionColW}|>{\raggedright\arraybackslash}p{\QuizAnswerColW}|}
      \ifstrempty{#1}{}{%
        \multicolumn{3}{|l|}{\cellcolor[HTML]{C0C0C0}\quiz@sectioncellwithvspace{\textbf{#1}}} \\
        \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
      }%
      \begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#2}\endgroup
        & \quiz@cellwithvspace{#3}
        & \quiz@cellwithvspace{} \\
      \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
    \end{tabular*}%
  }%
}

\newcommand{\quiz@blockrow@simple}[4]{%
  \makebox[\QuizBlockW][l]{%
    \begin{tabular*}{\QuizBlockW}{|>{\raggedleft\arraybackslash}p{\QuizNoColW}!{\vrule width \QuizNoSepRuleW}>{\raggedright\arraybackslash}p{\QuizQuestionColW}|>{\raggedright\arraybackslash}p{\QuizAnswerColW}|}
      \ifstrempty{#1}{}{%
        \multicolumn{3}{|l|}{\cellcolor[HTML]{C0C0C0}\quiz@sectioncellwithvspace{\textbf{#1}}} \\
        \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
      }%
      {\fontsize{10pt}{12pt}\selectfont #2}
        & \begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#3}\endgroup
        & \quiz@cellwithvspace{#4} \\
      \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
    \end{tabular*}%
  }%
}

\newcommand{\quiz@blockrow@withcomment}[5]{%
  \makebox[\QuizBlockW][l]{%
    \begin{tabular*}{\QuizBlockW}{|>{\raggedleft\arraybackslash}p{\QuizNoColW}!{\vrule width \QuizNoSepRuleW}>{\raggedright\arraybackslash}p{\QuizQuestionColW}|>{\raggedright\arraybackslash}p{\QuizAnswerColW}|}
      \ifstrempty{#1}{}{%
        \multicolumn{3}{|l|}{\cellcolor[HTML]{C0C0C0}\quiz@sectioncellwithvspace{\textbf{#1}}} \\
        \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
      }%
      {\fontsize{10pt}{12pt}\selectfont #2}
        & \begingroup\let\label\quiz@questionlabel\quiz@cellwithvspace{#3}\endgroup
        & \quiz@cellwithvspace{#4} \\
      \cline{2-3}
      \mbox{}
        & \multicolumn{2}{>{\raggedright\arraybackslash}p{\QuizCommentColW}|}{\begingroup\let\label\quiz@questionlabel\quiz@commentcell{#5}\endgroup} \\
      \specialrule{\QuizQuestionSepRuleW}{0pt}{0pt}
    \end{tabular*}%
  }%
}

\newcommand{\quiz@starttable}{%
  \quiz@recalcwidths
  \quiz@applytablemetrics
  \begin{longtable}{@{}p{\QuizBlockW}@{}}
  \quiz@headerblock \\
  \endfirsthead
  \quiz@headerblock \\
  \quiz@continuedsectionblock
  \endhead
  \endfoot
  \endlastfoot
  \global\quiz@opentrue
}

\newcommand{\quiz@emitquestionblock}[3]{%
  \ifnum\value{question}<\quiz@renumberstart
    \setcounter{question}{\numexpr\quiz@renumberstart-1\relax}%
  \fi
  \refstepcounter{question}%
  \global\quiz@hasquestiontrue
  \xdef\quiz@lastquestion{\thequestion}%
  \protected@edef\@currentlabel{\quiz@lastquestion}%
  \ifquiz@pendingsection
    \quiz@setactivesection{\quiz@pendingsectiontitle}%
    \quiz@ifblankTF{#3}{%
      \quiz@blockrow@simple{\quiz@pendingsectiontitle}{\thequestion}{#1}{#2} \\
    }{%
      \quiz@blockrow@withcomment{\quiz@pendingsectiontitle}{\thequestion}{#1}{#2}{#3} \\
    }%
    \quiz@clearpendingsection
  \else
    \quiz@ifblankTF{#3}{%
      \quiz@blockrow@simple{}{\thequestion}{#1}{#2} \\
    }{%
      \quiz@blockrow@withcomment{}{\thequestion}{#1}{#2}{#3} \\
    }%
  \fi
}

% ====================
% API
% ====================

\newcommand{\QuizSection}[1]{%
  \ifquiz@open\else
    \setlength{\LTpre}{\medskipamount}%
    \quiz@starttable
  \fi
  \quiz@setpendingsection{#1}%
}

\newcommand{\question}[3]{%
  \ifquiz@open\else
    \setlength{\LTpre}{\medskipamount}%
    \quiz@starttable
  \fi
  \quiz@emitquestionblock{#1}{#2}{#3}%
}

\newcommand{\renumber}[1]{%
  \ifstrempty{#1}{%
    \global\quiz@renumberstart=1%
  }{%
    \ifnum\numexpr#1\relax<1
      \global\quiz@renumberstart=1%
    \else
      \global\quiz@renumberstart=#1%
    \fi
  }%
  \setcounter{question}{\numexpr\quiz@renumberstart-1\relax}%
}

\newcommand{\QuestionLabel}[1]{%
  \ifquiz@hasquestion
    \quiz@questionlabel{#1}%
  \else
    \PackageWarning{quizsheet}{\string\QuestionLabel called before first question; label `#1' ignored}%
  \fi
}

\newcommand{\QuestionRef}[1]{Q\ref{#1}}

\newcommand{\QuestionPageRef}[1]{\pageref{#1}ページのQ\ref{#1}}

\newcommand{\QuestionRangeRef}[2]{Q\ref{#1}〜Q\ref{#2}}

\newcommand{\qref}[1]{\QuestionRef{#1}}

\newcommand{\qpageref}[1]{\QuestionPageRef{#1}}

\newcommand{\qrefrange}[2]{\QuestionRangeRef{#1}{#2}}

\newcommand{\quizclose}{%
  \ifquiz@open
    \end{longtable}%
    \quiz@restoretablemetrics
    \global\quiz@openfalse
    \quiz@clearpendingsection
    \quiz@clearactivesection
    \setlength{\LTpre}{\medskipamount}%
  \fi
}

\newcommand{\quizend}[1]{%
  \ifquiz@open
    \vspace{\the\dimexpr -\f@size pt-3pt\relax}%
    \makebox[\linewidth][r]{\small #1} \\
    \end{longtable}%
    \quiz@restoretablemetrics
    \global\quiz@openfalse
    \quiz@clearpendingsection
    \quiz@clearactivesection
    \setlength{\LTpre}{\medskipamount}%
  \fi
}

\pretocmd{\clearpage}{\quizclose}{}{}
\pretocmd{\section}{\quizclose\quiz@clearpendingsection\quiz@clearactivesection\setcounter{question}{0}}{}{}
\pretocmd{\subsection}{\quizclose\quiz@clearpendingsection\quiz@clearactivesection}{}{}
\pretocmd{\subsubsection}{\quizclose\quiz@clearpendingsection\quiz@clearactivesection}{}{}

\AtEndDocument{\quizclose}

\endinput
